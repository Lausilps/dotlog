{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/feedback/**",
              "components/surfaces/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Press Start 2P|VT323|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Press Start 2P, VT323, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:amarelo|creme|verde|vermelho|cinza)$/]",
        "message": "<Badge> color must be one of 'amarelo' | 'creme' | 'verde' | 'vermelho' | 'cinza'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:hover|accent|shadow|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: hover, accent, shadow, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='DialogBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:avatar|arrow|prompt|cursor|children|style|key|ref|className|style|children)$/]",
        "message": "<DialogBox> doesn't accept that prop. Declared props: avatar, arrow, prompt, cursor, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascote'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|size|float|alt|style|key|ref|className|style|children)$/]",
        "message": "<Mascote> doesn't accept that prop. Declared props: src, size, float, alt, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|segments|label|showValue|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, segments, label, showValue, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkles'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|color|style|key|ref|className|style|children)$/]",
        "message": "<Sparkles> doesn't accept that prop. Declared props: count, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WindowFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|style|key|ref|className|style|children)$/]",
        "message": "<WindowFrame> doesn't accept that prop. Declared props: title, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
